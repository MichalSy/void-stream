{
  "app": {
    "name": "Void Stream",
    "url": "https://void-stream.sytko.de",
    "description": "Nerd-grade video streaming platform"
  },
  "auth": {
    "enabled": true,
    "provider": "google",
    "loginTitle": "Void Stream",
    "loginSubtitle": "Enter the void",
    "successRedirect": "/player"
  },
  "pages": [
    { "path": "/player", "label": "Player", "icon": "🎬" }
  ],
  "abilities": {
    "enabled": true,
    "list": [
      {
        "id": "access",
        "name": "Passierschein",
        "emoji": "🎫",
        "description": "Zugang zu Void Stream",
        "is_passierschein": true
      }
    ]
  },
  "routes": {
    "protected": ["/player"],
    "public": ["/", "/login", "/auth/callback", "/api/extract"]
  },
  "theme": {
    "primaryColor": "#6366f1",
    "secondaryColor": "#8b5cf6"
  }
}
